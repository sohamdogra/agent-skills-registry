# ── Photon / Spectrum credentials ────────────────────────────────────────
# Get these from your project at https://app.photon.codes
# PROJECT_ID is safe to share; keep PROJECT_SECRET private (rotate it if it leaks).
PROJECT_ID=
PROJECT_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────
# Override which model the agent uses (defaults to the VM's configured model).
# HERMES_MODEL=anthropic/claude-sonnet-4
#
# Override the hermes binary name/path if it isn't just "hermes" on PATH.
# HERMES_BIN=hermes
